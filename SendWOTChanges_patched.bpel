                                    <invoke xmlns:bpelx="http://schemas.oracle.com/bpel/extension" name="InvokePutVideosPACP" partnerLink="SewerAIVideos" portType="vid:SewerAIVideos_ptt" operation="putVideosPACP" inputVariable="putVideosPACP_In" outputVariable="vPutVideosResp" bpelx:invokeAsDetail="yes">
