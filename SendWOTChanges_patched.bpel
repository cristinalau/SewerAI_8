                                        <bpelx:toProperty name="rest.binding.responseType" variable="vRespType"/>
                                      </bpelx:toProperties>
                                                                          </invoke>
                                  <assign name="SetPutVideosPACPSentStatus" bpelx:insertMissingToData="yes">
  <copy><from>'SENT'</from><to>$vFeedStatus</to></copy>
  <copy><from>'OK'</from><to>$vFeedMessage</to></copy>
</assign></sequence>
