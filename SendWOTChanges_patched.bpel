                                normalize-space(string($InvokeReadCRInspect_ReadCRInspectSelect_OutputVariable.VCrInspectToSendCollection/topCRI:VCrInspectToSend[$i]/topCRI:inspectionid))
                              </from>
                              <to>$UpdateCRInspectStatus_In.EpseweraiCrInspectCollection/topUCS:EpseweraiCrInspect/topUCS:inspectionid</to>
                            </copy>
                            <copy>
                              <from>$vFeedStatus</from>
                              <to>$UpdateCRInspectStatus_In.EpseweraiCrInspectCollection/topUCS:EpseweraiCrInspect/topUCS:feedStatus</to>
                            </copy>
                          </assign><!-- Now actually call the DB adapter -->
                          <invoke xmlns:bpelx="http://schemas.oracle.com/bpel/extension" name="InvokeUpdateCRInspectStatus" partnerLink="UpdateCRInspectStatus" portType="uc:UpdateCRInspectStatus_ptt" operation="update" inputVariable="UpdateCRInspectStatus_In" bpelx:invokeAsDetail="yes"/>
                        </sequence>
                      </if>
                    </sequence>
                  </scope>
                </forEach>
              </sequence>
              <else>
